generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth standard tables ───────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts    Account[]
  sessions    Session[]
  memberships OrgMembership[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
  // Failed verification attempts; the token is deleted once a small budget is
  // exhausted so short numeric codes can't be brute-forced.
  attempts   Int      @default(0)

  @@unique([identifier, token])
}

// ─── App models ─────────────────────────────────────────────────────

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logoUrl     String? // data URI or URL shown on the consent screen
  suspendedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberships  OrgMembership[]
  connectors   Connector[]
  llmProviders LlmProvider[]
  channels     Channel[]
  settings     OrgSettings?
}

model OrgSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Notification preferences
  notifyEmail           Boolean @default(true)
  notifyWebhookUrl      String?
  notifySlackWebhookUrl String?

  // Log retention
  logRetentionDays Int @default(90)

  // Member auth settings
  defaultSessionDurationHours Int     @default(720) // 30 days
  allowedAuthProviders        Json    @default("[\"EMAIL\",\"GOOGLE\",\"GITHUB\"]")
  require2FA                  Boolean @default(false)

  // AI settings
  aiFilterEnabled      Boolean @default(true)
  aiModel              String  @default("claude-sonnet-4-20250514") // env-fallback model when no LlmProvider is configured
  defaultLlmProviderId String? // selected LlmProvider used by the AI filter (and chat later)
  approvalTimeoutSecs  Int     @default(300) // 5 minutes

  // Channels: when false, Message rows are still written for audit/turn count
  // but `content` and `toolCalls` bodies are stored as null.
  channelPersistMessageBodies Boolean @default(true)
}

// Replaces both Admin and Member models
model OrgMembership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrgRole      @default(MEMBER)
  status         MemberStatus @default(INVITED)

  // Kill switch — when set, all MCP access is blocked instantly.
  suspendedAt DateTime?

  // Auth session config — overrides org default if set
  sessionDurationHours Int?

  // The team member's job title within the organization (e.g. "Marketing Manager").
  jobTitle String?

  // Admin-only description of role, responsibilities, job duties. Fed to the AI
  // filter as context so the LLM knows what the member is supposed to do.
  // Never shown to the member themselves.
  responsibilities String? @db.Text

  // Global natural-language permission instructions (only for MEMBER role)
  permissionInstructions String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  connectorAccess   MemberConnectorAccess[]
  toolAccess        MemberToolAccess[]
  auditLogs         AuditLog[]
  approvalRequests  ApprovalRequest[]
  mcpTokens         McpToken[]
  channelIdentities ChannelIdentity[]
  channelLinkCodes  ChannelLinkCode[]
  conversations     Conversation[]

  @@unique([userId, organizationId])
  @@index([organizationId])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum MemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REVOKED
}

// MCP access tokens. Minted either from the dashboard (personal access tokens,
// null OAuth fields) or via the OAuth 2.1 flow (clientId/scope/resource set).
model McpToken {
  id           String        @id @default(cuid())
  membershipId String
  membership   OrgMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  accessToken  String        @unique
  expiresAt    DateTime
  createdAt    DateTime      @default(now())
  lastUsedAt   DateTime      @default(now())

  // OAuth-issued tokens only (null for dashboard-minted personal tokens)
  clientId         String?
  scope            String?
  resource         String?
  refreshTokenHash String?   @unique
  refreshExpiresAt DateTime?

  @@index([accessToken])
  @@index([membershipId])
}

// ─── OAuth 2.1 authorization server (MCP Authorization spec) ─────────

// Registered OAuth clients (via Dynamic Client Registration, RFC 7591).
model OAuthClient {
  id                      String   @id @default(cuid())
  clientId                String   @unique
  clientSecretHash        String? // null = public client (PKCE only)
  redirectUris            String[]
  clientName              String?
  logoUri                 String? // RFC 7591 logo_uri, shown on the consent screen
  tokenEndpointAuthMethod String   @default("none") // "none" | "client_secret_post"
  grantTypes              String[] @default(["authorization_code", "refresh_token"])
  createdAt               DateTime @default(now())
}

// Short-lived single-use authorization codes (OAuth 2.1 + PKCE).
model OAuthAuthorizationCode {
  id                  String    @id @default(cuid())
  codeHash            String    @unique
  clientId            String
  membershipId        String
  redirectUri         String
  codeChallenge       String
  codeChallengeMethod String    @default("S256")
  scope               String?
  resource            String
  expiresAt           DateTime
  consumedAt          DateTime?
  createdAt           DateTime  @default(now())
}

model Connector {
  id                   String          @id @default(cuid())
  organizationId       String
  organization         Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                 String
  type                 ConnectorType
  credentialsEncrypted String          @db.Text
  config               Json            @default("{}")
  skipAiFilter         Boolean         @default(false)
  status               ConnectorStatus @default(ACTIVE)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  memberAccess MemberConnectorAccess[]
  tools        ConnectorTool[]
  auditLogs    AuditLog[]
  oauth        ConnectorOAuth?
}

enum ConnectorType {
  POSTGRES
  MYSQL
  MONGODB
  STRIPE
  EXTERNAL_MCP
  WEB_REQUEST
  CUSTOM
}

// A per-org LLM provider connection. Powers the AI filter today; chat/agent surfaces later.
model LlmProvider {
  id              String            @id @default(cuid())
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  type            LlmProviderType
  apiKeyEncrypted String?           @db.Text // AES-256-GCM; optional for keyless custom endpoints
  baseUrl         String? // required for CUSTOM_OPENAI; optional override for others
  defaultModel    String // free-text model id (presets suggested in UI)
  config          Json              @default("{}") // optional extraHeaders, etc.
  status          LlmProviderStatus @default(ACTIVE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([organizationId])
}

enum LlmProviderType {
  OPENAI
  ANTHROPIC
  XAI
  KIMI
  OPENROUTER
  CUSTOM_OPENAI
}

enum LlmProviderStatus {
  ACTIVE
  DISABLED
  ERROR
}

enum ConnectorStatus {
  ACTIVE
  DISABLED
  ERROR
  PENDING
}

// OAuth 2.1 state for an EXTERNAL_MCP connector (1:1). Secret blobs are
// AES-256-GCM encrypted; the SDK refreshes tokens in place via this row.
model ConnectorOAuth {
  id             String    @id @default(cuid())
  connectorId    String    @unique
  connector      Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  serverUrl      String
  scope          String?
  clientInfoEnc  String?   @db.Text // encrypt(JSON OAuthClientInformationFull) — DCR or manual
  tokensEnc      String?   @db.Text // encrypt(JSON OAuthTokens)
  discoveryState Json? // OAuthDiscoveryState (non-secret; avoids re-discovery)
  codeVerifier   String?   @db.Text // transient PKCE verifier, cleared after callback
  state          String?   @unique // transient CSRF state param, cleared after callback
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ConnectorTool {
  id          String    @id @default(cuid())
  connectorId String
  connector   Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  toolName    String
  description String?   @db.Text
  inputSchema Json?
  enabled     Boolean   @default(true)

  memberAccess MemberToolAccess[]

  @@unique([connectorId, toolName])
}

model MemberConnectorAccess {
  id           String        @id @default(cuid())
  membershipId String
  membership   OrgMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  connectorId  String
  connector    Connector     @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  readAccess        Boolean @default(true)
  writeAccess       Boolean @default(false)
  nativePermissions Json?
  customScript      String? @db.Text
  aiInstructions    String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([membershipId, connectorId])
}

model MemberToolAccess {
  id              String        @id @default(cuid())
  membershipId    String
  membership      OrgMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  connectorToolId String
  connectorTool   ConnectorTool @relation(fields: [connectorToolId], references: [id], onDelete: Cascade)

  allowed               Boolean @default(true)
  aiInstructionOverride String? @db.Text

  @@unique([membershipId, connectorToolId])
}

model AuditLog {
  id             String        @id @default(cuid())
  membershipId   String
  membership     OrgMembership @relation(fields: [membershipId], references: [id])
  connectorId    String?
  connector      Connector?    @relation(fields: [connectorId], references: [id])
  organizationId String

  toolName        String
  requestParams   Json?
  responseSummary String?     @db.Text
  aiDecision      AiDecision?
  aiReasoning     String?     @db.Text
  scriptResult    Json?
  durationMs      Int?
  timestamp       DateTime    @default(now())

  @@index([organizationId, timestamp])
  @@index([membershipId, timestamp])
  @@index([connectorId, timestamp])
}

enum AiDecision {
  PASSED
  FILTERED
  BLOCKED
  QUEUED
  SKIPPED
}

model ApprovalRequest {
  id             String        @id @default(cuid())
  membershipId   String
  membership     OrgMembership @relation(fields: [membershipId], references: [id])
  organizationId String

  connectorName  String
  toolName       String
  requestContext Json
  aiReasoning    String         @db.Text
  status         ApprovalStatus @default(PENDING)
  adminResponse  String?        @db.Text
  respondedAt    DateTime?
  ruleUpdate     String?        @db.Text
  expiresAt      DateTime
  createdAt      DateTime       @default(now())

  @@index([organizationId, status])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED
}

// ─── Channels — multi-surface agentic chat ─────────────────────────

// One configured chat surface for an org: a web chat, a Telegram bot, a
// WhatsApp bot, a Slack app, etc. The org brings its own bot credentials —
// nothing is centralized.
model Channel {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name   String
  type   ChannelType
  status ChannelStatus @default(ACTIVE)

  // AES-256-GCM blob; per-channel-type shape (e.g. Telegram bot token,
  // Slack signing secret + bot token, WhatsApp app secret + access token).
  // Null only for the WEB channel.
  credentialsEncrypted String? @db.Text

  // Per-channel-type non-secret config (e.g. Slack team_id, WhatsApp phone_number_id).
  config Json @default("{}")

  // Random secret we attach to outbound webhook registrations (e.g. Telegram
  // setWebhook secret_token) and verify on inbound requests.
  webhookSecret String

  // Optional model override; falls back to OrgSettings.aiModel / env.
  modelOverride        String?
  // Optional LlmProvider override per channel.
  defaultLlmProviderId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identities    ChannelIdentity[]
  linkCodes     ChannelLinkCode[]
  conversations Conversation[]

  @@index([organizationId])
}

enum ChannelType {
  WEB
  TELEGRAM
  WHATSAPP
  SLACK
}

enum ChannelStatus {
  ACTIVE
  DISABLED
  ERROR
}

// Maps an external identity on a channel (Telegram chat_id, Slack user id,
// WhatsApp wa_id, or — for WEB — the NextAuth user id) to one OrgMembership.
// A member can link many identities across many channels.
model ChannelIdentity {
  id           String        @id @default(cuid())
  channelId    String
  channel      Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  membershipId String
  membership   OrgMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  externalId  String
  displayName String?

  linkedAt DateTime @default(now())

  conversations Conversation[]

  @@unique([channelId, externalId])
  @@index([membershipId])
}

// Short-lived hashed one-time code an employee generates in the admin UI and
// sends to the bot to bind their external identity to their membership.
model ChannelLinkCode {
  id           String        @id @default(cuid())
  channelId    String
  channel      Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  membershipId String
  membership   OrgMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  codeHash   String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([channelId])
}

// A chat thread on a channel. For WEB this is a UI-side conversation; for bot
// channels it tracks the external thread (telegram chat_id, slack channel ts).
model Conversation {
  id                String          @id @default(cuid())
  channelId         String
  channel           Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelIdentityId String
  channelIdentity   ChannelIdentity @relation(fields: [channelIdentityId], references: [id], onDelete: Cascade)
  membershipId      String
  membership        OrgMembership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  externalThreadId String?
  title            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@index([channelId, updatedAt])
  @@index([membershipId, updatedAt])
}

// One agent-loop event. Privacy mode (`OrgSettings.channelPersistMessageBodies`)
// keeps the row for audit but nulls out content + toolCalls bodies.
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role      MessageRole
  content   String?     @db.Text
  toolCalls Json?
  toolName  String?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
  TOOL
}
